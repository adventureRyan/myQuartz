
"smart_sources:10 zotero/zotero_annotations/Actional-Structural Graph Convolutional Networks for Skeleton-based Action Recognition.md": {"path":"10 zotero/zotero_annotations/Actional-Structural Graph Convolutional Networks for Skeleton-based Action Recognition.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"4c68e5fe31629ab7757691c27478b618379af252e070ea57c96df65b65981366","at":1746018163171},"class_name":"SmartSource","last_import":{"mtime":1712324180000,"size":7240,"at":1746018163171,"hash":"4c68e5fe31629ab7757691c27478b618379af252e070ea57c96df65b65981366"},"blocks":{"#---frontmatter---":[1,9],"#":[10,20],"#参考网站":[21,29],"#参考网站#{1}":[22,29],"#Self Notes":[30,68],"#Self Notes#{1}":[31,31],"#Self Notes#概念理解":[32,38],"#Self Notes#概念理解#关键句":[33,38],"#Self Notes#概念理解#关键句#{1}":[34,38],"#Self Notes#公式理解":[39,68],"#Self Notes#公式理解#1.对 $\\mathbf{X}_{\\mathrm{out}}=\\sum_{p \\in \\mathcal{P}} \\mathbf{M}_{\\mathrm{st}}^{(p)} \\circ \\widetilde{\\mathbf{A}^{(p)}} \\mathbf{X}_{\\mathrm{in}} \\mathbf{W}_{\\mathrm{st}}^{(p)}$ 的理解":[40,43],"#Self Notes#公式理解#1.对 $\\mathbf{X}_{\\mathrm{out}}=\\sum_{p \\in \\mathcal{P}} \\mathbf{M}_{\\mathrm{st}}^{(p)} \\circ \\widetilde{\\mathbf{A}^{(p)}} \\mathbf{X}_{\\mathrm{in}} \\mathbf{W}_{\\mathrm{st}}^{(p)}$ 的理解#{1}":[41,43],"#Self Notes#公式理解#2. $\\begin{aligned} & \\text { link features : } \\mathbf{Q}_{i, j}^{(k+1)}=f_e^{(k)}\\left(f_v^{(k)}\\left(\\mathbf{p}_i^{(k)}\\right) \\oplus\\left(f_v^{(k)}\\left(\\mathbf{p}_j^{(k)}\\right)\\right),\\right. \\\\ & \\text { joint features : } \\mathbf{p}_i^{(k+1)}=\\mathcal{F}\\left(\\mathbf{Q}_{i,:}^{(k+1)}\\right) \\oplus \\mathbf{p}_i^{(k)}\\end{aligned}$ 的理解":[44,57],"#Self Notes#公式理解#2. $\\begin{aligned} & \\text { link features : } \\mathbf{Q}_{i, j}^{(k+1)}=f_e^{(k)}\\left(f_v^{(k)}\\left(\\mathbf{p}_i^{(k)}\\right) \\oplus\\left(f_v^{(k)}\\left(\\mathbf{p}_j^{(k)}\\right)\\right),\\right. \\\\ & \\text { joint features : } \\mathbf{p}_i^{(k+1)}=\\mathcal{F}\\left(\\mathbf{Q}_{i,:}^{(k+1)}\\right) \\oplus \\mathbf{p}_i^{(k)}\\end{aligned}$ 的理解#{1}":[46,57],"#Self Notes#公式理解#3. 对 $\\mathcal{A}_{i, j,:}=\\operatorname{softmax}\\left(\\frac{\\mathbf{Q}_{i, j}^{(K)}+\\mathbf{r}}{\\tau}\\right) \\in \\mathbb{R}^C$ 的理解":[58,68],"#Self Notes#公式理解#3. 对 $\\mathcal{A}_{i, j,:}=\\operatorname{softmax}\\left(\\frac{\\mathbf{Q}_{i, j}^{(K)}+\\mathbf{r}}{\\tau}\\right) \\in \\mathbb{R}^C$ 的理解#{1}":[59,59],"#Self Notes#公式理解#3. 对 $\\mathcal{A}_{i, j,:}=\\operatorname{softmax}\\left(\\frac{\\mathbf{Q}_{i, j}^{(K)}+\\mathbf{r}}{\\tau}\\right) \\in \\mathbb{R}^C$ 的理解#{2}":[60,60],"#Self Notes#公式理解#3. 对 $\\mathcal{A}_{i, j,:}=\\operatorname{softmax}\\left(\\frac{\\mathbf{Q}_{i, j}^{(K)}+\\mathbf{r}}{\\tau}\\right) \\in \\mathbb{R}^C$ 的理解#{3}":[61,61],"#Self Notes#公式理解#3. 对 $\\mathcal{A}_{i, j,:}=\\operatorname{softmax}\\left(\\frac{\\mathbf{Q}_{i, j}^{(K)}+\\mathbf{r}}{\\tau}\\right) \\in \\mathbb{R}^C$ 的理解#{4}":[62,63],"#Self Notes#公式理解#3. 对 $\\mathcal{A}_{i, j,:}=\\operatorname{softmax}\\left(\\frac{\\mathbf{Q}_{i, j}^{(K)}+\\mathbf{r}}{\\tau}\\right) \\in \\mathbb{R}^C$ 的理解#{5}":[64,68],"#Reading notes":[69,79],"#Reading notes#{1}":[70,79]},"outlinks":[{"title":"Li 等 - 2019 - Actional-Structural Graph Convolutional Networks f.pdf","target":"zotero://select/library/items/6AAH25CS","line":12},{"title":"http://arxiv.org/abs/1904.12659","target":"http://arxiv.org/abs/1904.12659","line":18},{"title":"Medium 网站","target":"https://medium.com/%E4%BA%BA%E5%B7%A5%E6%99%BA%E6%85%A7-%E5%80%92%E5%BA%95%E6%9C%89%E5%A4%9A%E6%99%BA%E6%85%A7/%E8%AB%96%E6%96%87%E9%96%B1%E8%AE%80-cvpr-2019-actional-structural-graph-convolutional-networks-for-skeleton-based-action-f3b5bdf5d6e8","line":23}],"metadata":{"tags":null,"title":"Actional-Structural Graph Convolutional Networks for Skeleton-based Action Recognition","authors":"Maosen Li, Siheng Chen, Xu Chen, Ya Zhang, Yanfeng Wang, Qi Tian","year":2019,"publisher":null,"keywords":["reading"],"citekey":"liActionalStructuralGraphConvolutional2019c"}},
